{
  "$description": "Inkblot Studio dark mode semantic overrides. Apply via [data-theme='dark'] or prefers-color-scheme.",
  "inkblot": {
    "dark": {
      "color": {
        "$type": "color",
        "$description": "Dark mode color overrides — map to the same semantic keys as light mode",
        "background": {
          "primary": { "$value": "#000000", "$description": "True black for OLED and depth" },
          "secondary": { "$value": "#1c1c1e", "$description": "Elevated surface" },
          "tertiary": { "$value": "#2c2c2e", "$description": "Grouped content surface" },
          "inverse": { "$value": "#ffffff", "$description": "Inverted surface" }
        },
        "text": {
          "primary": { "$value": "#f5f5f7", "$description": "Primary text on dark - 7:1 AAA on #000" },
          "secondary": { "$value": "#8e8e93", "$description": "Secondary text" },
          "tertiary": { "$value": "#636366", "$description": "Placeholder, hints" },
          "inverse": { "$value": "#1c1c1e", "$description": "Text on light surfaces" },
          "link": { "$value": "#409cff", "$description": "Link on dark - brighter for contrast" },
          "linkHover": { "$value": "#64b5ff", "$description": "Link hover on dark" }
        },
        "border": {
          "default": { "$value": "#38383a", "$description": "Subtle border on dark" },
          "strong": { "$value": "#48484a", "$description": "Emphasized border on dark" },
          "focus": { "$value": "#409cff", "$description": "Focus ring on dark" }
        },
        "interactive": {
          "primary": { "$value": "#0a84ff", "$description": "Primary action on dark" },
          "primaryHover": { "$value": "#409cff", "$description": "Primary hover on dark" },
          "primaryActive": { "$value": "#0066d6", "$description": "Primary pressed on dark" },
          "secondary": { "$value": "#2c2c2e", "$description": "Secondary button on dark" },
          "secondaryHover": { "$value": "#3a3a3c", "$description": "Secondary hover on dark" }
        },
        "status": {
          "success": { "$value": "#30d158", "$description": "Success on dark" },
          "warning": { "$value": "#ffd60a", "$description": "Warning on dark" },
          "error": { "$value": "#ff453a", "$description": "Error on dark" },
          "info": { "$value": "#64d2ff", "$description": "Info on dark" }
        }
      }
    }
  }
}
