{
  "$description": "Inkblot Studio primitive color palette. Apple-inspired: clean, sophisticated, accessible. sRGB color space.",
  "inkblot": {
    "$description": "Inkblot Studio design token primitives",
    "color": {
      "$type": "color",
      "$description": "Base color primitives - use semantic tokens in components",
      "neutral": {
        "$type": "color",
        "white": {
          "$value": "#ffffff",
          "$description": "Pure white, primary backgrounds"
        },
        "gray": {
          "50": { "$value": "#fafafa", "$description": "Lightest gray, subtle backgrounds" },
          "100": { "$value": "#f5f5f5", "$description": "Very light gray" },
          "200": { "$value": "#ebebeb", "$description": "Light gray, borders" },
          "300": { "$value": "#d1d1d6", "$description": "Medium light gray" },
          "400": { "$value": "#8e8e93", "$description": "Medium gray, placeholder text" },
          "500": { "$value": "#636366", "$description": "Gray" },
          "600": { "$value": "#48484a", "$description": "Dark gray" },
          "700": { "$value": "#3a3a3c", "$description": "Darker gray" },
          "800": { "$value": "#2c2c2e", "$description": "Dark" },
          "900": { "$value": "#1c1c1e", "$description": "Darkest, primary text" },
          "950": { "$value": "#000000", "$description": "Pure black" }
        }
      },
      "accent": {
        "$type": "color",
        "$description": "Primary brand accent - refined blue, Apple-inspired",
        "blue": {
          "50": { "$value": "#e8f4ff", "$description": "Lightest blue tint" },
          "100": { "$value": "#c7e3ff", "$description": "Very light blue" },
          "200": { "$value": "#a1d0ff", "$description": "Light blue" },
          "300": { "$value": "#6eb8ff", "$description": "Medium light blue" },
          "400": { "$value": "#3d9eff", "$description": "Blue" },
          "500": { "$value": "#007aff", "$description": "Primary accent - Apple system blue" },
          "600": { "$value": "#0066d6", "$description": "Hover/pressed state" },
          "700": { "$value": "#0052ad", "$description": "Active state" },
          "800": { "$value": "#003d84", "$description": "Dark blue" },
          "900": { "$value": "#002952", "$description": "Darkest blue" }
        }
      },
      "semantic": {
        "$type": "color",
        "$description": "Semantic colors - use for status, feedback, actions",
        "success": {
          "light": { "$value": "#34c759", "$description": "Success green" },
          "main": { "$value": "#30b350", "$description": "Primary success" },
          "dark": { "$value": "#248a3d", "$description": "Success hover" }
        },
        "warning": {
          "light": { "$value": "#ff9500", "$description": "Warning orange" },
          "main": { "$value": "#e68600", "$description": "Primary warning" },
          "dark": { "$value": "#cc7700", "$description": "Warning hover" }
        },
        "error": {
          "light": { "$value": "#ff3b30", "$description": "Error red" },
          "main": { "$value": "#e6352b", "$description": "Primary error" },
          "dark": { "$value": "#cc2f26", "$description": "Error hover" }
        },
        "info": {
          "light": { "$value": "#5ac8fa", "$description": "Info cyan" },
          "main": { "$value": "#007aff", "$description": "Primary info (matches accent)" },
          "dark": { "$value": "#0066d6", "$description": "Info hover" }
        }
      }
    }
  }
}
