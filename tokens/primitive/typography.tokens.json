{
  "$description": "Inkblot Studio typography scale. Apple-inspired: clear hierarchy, excellent readability.",
  "inkblot": {
    "typography": {
      "$type": "fontFamily",
      "$description": "Font families - system stack for native feel",
      "fontFamily": {
        "sans": {
          "$value": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif",
          "$description": "Primary UI font stack"
        },
        "mono": {
          "$value": "ui-monospace, 'SF Mono', 'SFMono-Regular', Menlo, Monaco, Consolas, monospace",
          "$description": "Code and data font stack"
        },
        "display": {
          "$value": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif",
          "$description": "Display/headline font"
        }
      },
      "fontSize": {
        "$type": "dimension",
        "$description": "Type scale - 1.25 modular scale (Major Third)",
        "xs": { "$value": "0.75rem", "$description": "12px - captions, labels" },
        "sm": { "$value": "0.8125rem", "$description": "13px - secondary text" },
        "base": { "$value": "1rem", "$description": "16px - body text" },
        "md": { "$value": "1.0625rem", "$description": "17px - emphasized body" },
        "lg": { "$value": "1.25rem", "$description": "20px - subheadings" },
        "xl": { "$value": "1.5rem", "$description": "24px - section titles" },
        "2xl": { "$value": "1.875rem", "$description": "30px - page titles" },
        "3xl": { "$value": "2.25rem", "$description": "36px - hero" },
        "4xl": { "$value": "3rem", "$description": "48px - display" },
        "5xl": { "$value": "3.75rem", "$description": "60px - large display" }
      },
      "fontWeight": {
        "$type": "fontWeight",
        "regular": { "$value": "400", "$description": "Body text" },
        "medium": { "$value": "500", "$description": "Emphasis" },
        "semibold": { "$value": "600", "$description": "Headings" },
        "bold": { "$value": "700", "$description": "Strong emphasis" }
      },
      "lineHeight": {
        "$type": "number",
        "tight": { "$value": 1.2, "$description": "Headlines" },
        "snug": { "$value": 1.375, "$description": "Subheadings" },
        "normal": { "$value": 1.5, "$description": "Body text" },
        "relaxed": { "$value": 1.625, "$description": "Long-form content" },
        "loose": { "$value": 2, "$description": "Spacious layouts" }
      },
      "letterSpacing": {
        "$type": "dimension",
        "tighter": { "$value": "-0.05em", "$description": "Large headlines" },
        "tight": { "$value": "-0.025em", "$description": "Headings" },
        "normal": { "$value": "0", "$description": "Body" },
        "wide": { "$value": "0.025em", "$description": "Labels, caps" },
        "wider": { "$value": "0.05em", "$description": "Uppercase labels" }
      }
    }
  }
}
