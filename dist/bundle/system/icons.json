      "dots":        { "description": "Alternative: three-dot pulse animation. Prefer for inline text loading." },
      "skeleton":    { "description": "Prefer skeleton component for content-area loading." },
      "rule": "Use spinner for actions (button, refresh). Use skeleton for content areas (cards, lists, pages)."
    },
    "sort": {
      "ascending":  { "icon": "arrow-up",      "react": "ArrowUp" },
