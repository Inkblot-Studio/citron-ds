  "accessibility": {
    "description": "Rules for accessible icon usage. AI: always follow these.",
    "decorativeIcons": {
      "rule": "Icons next to visible text are decorative. Set aria-hidden='true' on the SVG/icon element.",
      "example": "<button><CheckIcon aria-hidden='true' /> Save</button>"
    },
    "interactiveIcons": {
      "rule": "Icon-only buttons and links MUST have an aria-label describing the action.",
      "example": "<button aria-label='Close dialog'><XIcon aria-hidden='true' /></button>"
    },
    "statusIcons": {
      "rule": "Status icons should be paired with visually hidden text for screen readers, or use aria-label on the parent.",
      "example": "<span role='img' aria-label='Error'><AlertCircle aria-hidden='true' /></span>"
    },
    "toggleIcons": {
      "rule": "When icon swaps on toggle, update aria-label to reflect the NEW action (what clicking will do).",
      "example": "If eye icon is shown (password hidden), aria-label='Show password'. After toggle to eye-off, aria-label='Hide password'."
    },
    "loadingIcons": {
      "rule": "Spinning loaders must have aria-label='Loading' or be inside an aria-busy='true' container.",
      "reducedMotion": "Respect prefers-reduced-motion. Replace spinner with static 'Loading...' text or a pulsing dot."
    },
    "focusManagement": {
      "iconButtons": "Include in tab order (tabindex='0' or native <button>). Never use <div> or <span> for interactive icons.",
      "minTouchTarget": "44×44px minimum. If icon is smaller, expand clickable area with padding."
    },
    "colorIndependence": {
      "rule": "Never rely on color alone to convey meaning. Always pair colored status icons with a text label or distinct shape.",
      "example": "Error uses x-circle (unique shape) + red color + 'Error' text. Warning uses alert-triangle (unique shape) + amber color."
    }
  },

  "cssUtilities": {
    "description": "Ready-to-use CSS for icon integration. AI: include these in generated stylesheets.",
    "iconBase": ".icon { display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; width: var(--inkblot-size-icon-md); height: var(--inkblot-size-icon-md); }",
    "iconSizes": {
      "xs": ".icon-xs { width: 12px; height: 12px; }",
      "sm": ".icon-sm { width: var(--inkblot-size-icon-sm); height: var(--inkblot-size-icon-sm); }",
      "md": ".icon-md { width: var(--inkblot-size-icon-md); height: var(--inkblot-size-icon-md); }",
      "lg": ".icon-lg { width: var(--inkblot-size-icon-lg); height: var(--inkblot-size-icon-lg); }",
      "xl": ".icon-xl { width: 32px; height: 32px; }",
      "2xl": ".icon-2xl { width: 48px; height: 48px; }"
    },
    "iconButton": ".icon-button { display: inline-flex; align-items: center; justify-content: center; padding: var(--inkblot-spacing-2); border: none; background: transparent; border-radius: var(--inkblot-radius-md); cursor: pointer; min-width: var(--inkblot-size-touch-target-min); min-height: var(--inkblot-size-touch-target-min); transition: background var(--inkblot-duration-fast) var(--inkblot-easing-default); color: var(--inkblot-semantic-color-text-secondary); } .icon-button:hover { background: var(--inkblot-semantic-color-background-secondary); color: var(--inkblot-semantic-color-text-primary); } .icon-button:focus-visible { outline: 2px solid var(--inkblot-semantic-color-border-focus); outline-offset: 2px; }",
    "iconWithText": ".icon-text { display: inline-flex; align-items: center; gap: var(--inkblot-spacing-2); }",
    "iconSpin": ".icon-spin { animation: icon-spin 1s linear infinite; } @keyframes icon-spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }",
    "inputWithIcon": ".input-icon-wrapper { position: relative; } .input-icon-wrapper .input-icon { position: absolute; top: 50%; transform: translateY(-50%); pointer-events: none; color: var(--inkblot-semantic-color-text-tertiary); } .input-icon-wrapper .input-icon-leading { left: var(--inkblot-spacing-3); } .input-icon-wrapper .input-icon-trailing { right: var(--inkblot-spacing-3); pointer-events: auto; cursor: pointer; } .input-icon-wrapper input.has-icon-leading { padding-left: calc(var(--inkblot-size-icon-md) + var(--inkblot-spacing-3) + var(--inkblot-spacing-2)); } .input-icon-wrapper input.has-icon-trailing { padding-right: calc(var(--inkblot-size-icon-md) + var(--inkblot-spacing-3) + var(--inkblot-spacing-2)); }"
  }
}
